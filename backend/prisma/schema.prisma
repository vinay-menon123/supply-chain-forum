generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  username         String            @unique
  googleId         String?           @unique
  name             String?
  avatarUrl        String?
  role             Role              @default(USER)
  flagCount        Int               @default(0)
  isBanned         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  questions        Question[]
  comments         Comment[]
  votes            Vote[]
  sentMessages     Message[]         @relation("sentMessages")
  receivedMessages Message[]         @relation("receivedMessages")
  moderationEvents ModerationEvent[]
}

model Message {
  id        String    @id @default(cuid())
  body      String
  createdAt DateTime  @default(now())
  readAt    DateTime?
  from      User      @relation("sentMessages", fields: [fromId], references: [id], onDelete: Cascade)
  fromId    String
  to        User      @relation("receivedMessages", fields: [toId], references: [id], onDelete: Cascade)
  toId      String

  @@index([fromId, toId, createdAt])
  @@index([toId, readAt])
}

model ModerationEvent {
  id        String   @id @default(cuid())
  kind      String // question | comment | message
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  @@index([userId])
}

model Question {
  id         String    @id @default(cuid())
  title      String
  body       String
  imageUrl   String?
  shareCount Int       @default(0)
  createdAt  DateTime  @default(now())
  author     User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId   String
  comments   Comment[]
  votes      Vote[]

  @@index([createdAt])
}

model Comment {
  id         String   @id @default(cuid())
  body       String
  imageUrl   String?
  createdAt  DateTime @default(now())
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId   String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId String

  @@index([questionId])
}

model Vote {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionId String

  @@unique([userId, questionId])
}
